# ===========================================
# linkseek 生产环境配置
# ===========================================
# 复制为 .env.production 后替换所有占位值
# cp .env.production.example .env.production

# ---- 应用 ----
NODE_ENV=production
PORT=7300

# ---- 多域名分流 ----
# 后台管理域名（访问此 Host 走完整 Vue SPA）。
# 其余域名（含公开文档域名 linkseek.*）默认走「文档页 + MCP」。
ADMIN_DOMAIN=admin.linkseek.honlnk.com

# ---- 数据库 ----
# ⚠️ 密码必须与下面的 MYSQL_PASSWORD 一致
DATABASE_URL=mysql://linkseek:__MYSQL_PASSWORD__@linkseek-mysql:3306/linkseek

# MySQL 容器初始化用（首次创建数据库和用户）
MYSQL_ROOT_PASSWORD=__GENERATE_WITH_openssl_rand_hex_32__
MYSQL_USER=linkseek
MYSQL_PASSWORD=__MYSQL_PASSWORD__

# ---- 管理员 ----
# 首次部署后，在后台登录用此密码；之后可在后台修改
ADMIN_PASSWORD=__SET_A_STRONG_PASSWORD__

# 会话密钥：openssl rand -hex 32
SESSION_SECRET=__GENERATE_WITH_openssl_rand_hex_32__

# ---- 搜索后端 ----
# 容器间通信，用容器名
SEARXNG_URL=http://linkseek-searxng:8080

# ---- 出站 HTTP 代理（国内服务器访问境外站点）----
# 配置后 web_fetch / web_search_and_fetch 抓取目标站点时走 clash 代理。
# SearXNG 调用（内网）不走代理。未配置时直连。
HTTP_PROXY=http://172.17.0.1:7890
HTTPS_PROXY=http://172.17.0.1:7890
NO_PROXY=localhost,127.0.0.1,linkseek-app,linkseek-mysql,linkseek-searxng,linkseek-browser-fetch,linkseek-gateway,172.17.0.0/16

# ---- 浏览器渲染获取 ----
# Browserless v2 Playwright WS 端点（含 /chromium/playwright 路径）
BROWSER_FETCH_URL=ws://linkseek-browser-fetch:3000/chromium/playwright
BROWSER_FETCH_TIMEOUT=180000
# 设 false 可关闭 web_fetch_render 工具（未部署 browser-fetch 容器时）
BROWSER_FETCH_ENABLED=true

# ---- 安全 ----
# 生产环境必须开启严格模式
SSRF_STRICT=true

# ---- 兜底（生产用数据库，这里留空即可）----
API_KEYS=[]

# ---- Cookie ----
# 生产环境在 HTTPS 反代后面，设 true（需配合 trust proxy）
# 本地 HTTP 调试设 false
COOKIE_SECURE=true

# ---- 网页获取 ----
FETCH_TIMEOUT=30000
MAX_RESPONSE_SIZE=5242880
MAX_REDIRECTS=5

# ---- 日志 ----
LOG_LEVEL=info
# 生产环境用 JSON 日志（不用 pino-pretty）
LOG_PRETTY=false
