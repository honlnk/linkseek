# ============ 服务配置 ============
# HTTP 服务监听端口
PORT=3000

# ============ 数据库（第二阶段） ============
# 本地开发用 docker-compose 起的 MySQL 容器
DATABASE_URL=mysql://linkseek:linkseek_dev_pass@localhost:3306/linkseek

# ============ 管理员登录 ============
# 首次运行 prisma db seed 时用此密码初始化管理员账号
# 之后可在后台修改密码
ADMIN_PASSWORD=change-this-password

# 会话密钥（openssl rand -hex 32 生成）
SESSION_SECRET=

# ============ API Key 配置（第一阶段，无数据库时兜底） ============
# JSON 数组，每个 Key 代表一个使用方。
# 配置了 DATABASE_URL 时优先用数据库；此变量仅在无数据库时生效。
# 生成新 Key: openssl rand -hex 24，建议加前缀 wf_
API_KEYS=[]

# ============ SearXNG 搜索后端 ============
# 本地开发用 docker-compose 起的容器地址
SEARXNG_URL=http://localhost:8080

# ============ 网页获取配置 ============
# HTTP 请求超时（毫秒）
FETCH_TIMEOUT=30000
# 最大响应体大小（字节），超过则截断
MAX_RESPONSE_SIZE=5242880
# 重定向最大次数
MAX_REDIRECTS=5

# SSRF 严格模式：额外阻断 reserved/multicast 等地址段。
# 生产服务器建议设 true；若开发机使用 fake-ip 代理（如 Surge/Clash，
# 会把域名映射到 198.18.x.x），设 false 避免误伤。
SSRF_STRICT=false

# ============ 日志 ============
# 日志级别：trace/debug/info/warn/error
LOG_LEVEL=info
# 开发模式使用 pino-pretty 美化输出
LOG_PRETTY=true
