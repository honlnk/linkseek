{
  "name": "linkseek",
  "version": "0.1.0",
  "description": "自托管的远程 MCP 服务，提供联网搜索与网页获取能力",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "pnpm run db:generate && pnpm run web:build && tsc",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "web:dev": "pnpm --filter linkseek-admin dev",
    "web:build": "pnpm --filter linkseek-admin build"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "cheerio": "^1.2.0",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "ipaddr.js": "^2.4.0",
    "memorystore": "^1.6.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "prisma": "6.19.3",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^7.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2"
    ]
  }
}
